# =============================================================================
# Next.js Environment Variables (.env.local)
# =============================================================================
# Copy this file to .env.local and fill in the values below.
# Do NOT commit .env.local to version control.

# The Convex deployment URL for the React client.
# Find this in the Convex dashboard under your project → Settings → URL & Deploy Key.
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment-slug>.convex.cloud

# The Convex HTTP actions site URL, used by Better Auth server-side helpers
# to reach Convex HTTP endpoints. Typically the same host as above but with
# the `.site` domain suffix instead of `.cloud`.
# Find this in the Convex dashboard under your project → Settings → URL & Deploy Key.
NEXT_PUBLIC_CONVEX_SITE_URL=https://<your-deployment-slug>.convex.site

# =============================================================================
# Convex Dashboard Environment Variables
# =============================================================================
# The variable below is consumed by Convex backend functions (convex/auth.ts).
# Because it runs on the Convex runtime — not in Next.js — it CANNOT be set
# in this file. Add it in the Convex dashboard:
#   Project → Settings → Environment Variables
#
# SITE_URL — the publicly accessible base URL of this Next.js app.
# Better Auth uses this as its `baseURL` for callback and redirect URLs.
#
#   SITE_URL=https://example.com          # production
#   SITE_URL=http://localhost:3000        # local development
